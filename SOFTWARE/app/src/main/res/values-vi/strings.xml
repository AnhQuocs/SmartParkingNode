    <!-- ADMIN TERMS & PRIVACY -->
    <string name="admin_terms_title">Điều khoản sử dụng cho Quản trị viên</string>
    <string name="admin_terms_intro">Với tư cách là quản trị viên của hệ thống Smart Parking, bạn được cấp các quyền hạn nâng cao để quản lý hệ thống. Việc sử dụng các tính năng này phải tuân thủ các điều khoản sau.</string>
    <string name="admin_terms_section_1_title">1. Quyền hạn Quản trị</string>
    <string name="admin_terms_section_1_desc">Bạn chỉ được sử dụng quyền truy cập quản trị của mình cho mục đích quản lý hệ thống bãi xe, tài khoản người dùng và cấu hình phần cứng.</string>
    <string name="admin_terms_section_2_title">2. Quản lý Dữ liệu</string>
    <string name="admin_terms_section_2_desc">Quản trị viên có trách nhiệm duy trì tính chính xác và bảo mật của tất cả dữ liệu hệ thống, bao gồm thông tin cá nhân của người dùng và hồ sơ tài chính.</string>
    <string name="admin_terms_section_3_title">3. Trách nhiệm giải trình</string>
    <string name="admin_terms_section_3_desc">Tất cả các hành động quản trị đều được ghi lại. Bạn chịu trách nhiệm cho bất kỳ thay đổi nào được thực hiện bằng thông tin đăng nhập quản trị của mình.</string>
    <string name="admin_terms_section_4_title">4. Hành vi bị nghiêm cấm</string>
    <string name="admin_terms_section_4_desc">Nghiêm cấm chia sẻ mã quản trị trái phép, giả mạo nhật ký bảo mật hoặc truy cập dữ liệu cá nhân của người dùng cho các mục đích không thuộc hệ thống.</string>

    <string name="admin_privacy_title">Chính sách Bảo mật cho Quản trị viên</string>
    <string name="admin_privacy_intro">Chính sách này giải thích cách thức các hoạt động và dữ liệu quản trị được xử lý trong hệ thống Smart Parking.</string>
    <string name="admin_privacy_section_1_title">1. Thu thu thập dữ liệu quản trị</string>
    <string name="admin_privacy_section_1_desc">Chúng tôi thu thập dữ liệu liên quan đến các phiên quản trị của bạn, bao gồm địa chỉ IP, dấu thời gian và các hành động cụ thể được thực hiện trong bảng điều khiển quản lý.</string>
    <string name="admin_privacy_section_2_title">2. Sử dụng thông tin quản trị</string>
    <string name="admin_privacy_section_2_desc">Thông tin này được sử dụng để kiểm tra hệ thống, giám sát bảo mật và nâng cao hiệu suất cũng như độ tin cậy tổng thể của nền tảng.</string>
    <string name="admin_privacy_section_3_title">3. Kiểm soát truy cập</string>
    <string name="admin_privacy_section_3_desc">Chỉ các kiến trúc sư hệ thống cấp cao và nhân viên bảo mật được ủy quyền mới có quyền truy cập vào nhật ký quản trị để đảm bảo tính trách nhiệm và ngăn chặn lạm dụng quyền lực.</string>
    <string name="admin_privacy_section_4_title">4. Lưu trữ dữ liệu</string>
    <string name="admin_privacy_section_4_desc">Nhật ký quản trị được lưu giữ trong ít nhất 12 tháng để hỗ trợ các yêu cầu kiểm tra và điều tra bảo mật.</string>

